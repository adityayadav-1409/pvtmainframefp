000945                          WS-ACF-IO-BYTE.

000947     IF WS-ACF-IO-BYTE IS NOT EQUAL TO ZERO
000948         DISPLAY 'AGENT CONTROL FILE OPEN ERROR'
000949         GO TO EOJ9900-ABEND
000950     END-IF.

000952     SET CONTINUE-PROCESSING TO TRUE.
000953     MOVE '6' TO WS-IO-CODE.
000954     CALL 'CKVSAMIO' USING INFORCE-VSAM
000955                          WS-IO-CODE
000956                          INFORCE-FILE-AREA
000957                          INFORCE-FILE-LENGTH
000958                          INF-RECORD-KEY
000959                          INFORCE-VSAMX-INFO.

000961     IF WS-IO-CODE NOT EQUAL '0'
000962         DISPLAY 'OPEN INFORCE FAILED'
000963         DISPLAY 'WS-IO-CODE=' WS-IO-CODE
000964         GO TO EOJ9900-ABEND.
000968     CALL 'CKSDTIO' USING WS-IO-CODE
000969                          INFORCE-AUX-SDT.

000971     IF WS-IO-CODE NOT EQUAL '0'
000972         DISPLAY 'OPEN OF AUXSEG1 FILE FAILED'
000973         DISPLAY 'WS-IO-CODE=' WS-IO-CODE
000974         GO TO EOJ9900-ABEND.

000976     MOVE '6' TO WS-IO-CODE.
